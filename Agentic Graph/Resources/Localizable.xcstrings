    "All %lld agents use the same model. %lld simpler agents could use a smaller, cheaper model to reduce cost without quality impact." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يستخدم جميع الـ %1$lld وكلاء النموذج نفسه. يمكن لـ %2$lld وكلاء أبسط استخدام نموذج أصغر وأقل تكلفة لتقليل التكلفة دون التأثير على الجودة."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Všech %1$lld agentů používá stejný model. %2$lld jednodušších agentů by mohlo používat menší, levnější model pro snížení nákladů bez vlivu na kvalitu."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle %1$lld Agenten verwenden dasselbe Modell. %2$lld einfachere Agenten könnten ein kleineres, günstigeres Modell verwenden, um Kosten ohne Qualitätsverlust zu senken."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Και οι %1$lld πράκτορες χρησιμοποιούν το ίδιο μοντέλο. %2$lld απλούστεροι πράκτορες θα μπορούσαν να χρησιμοποιήσουν ένα μικρότερο, φθηνότερο μοντέλο για μείωση κόστους χωρίς επίπτωση στην ποιότητα."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los %1$lld agentes usan el mismo modelo. %2$lld agentes más simples podrían usar un modelo menor y más barato para reducir el coste sin afectar la calidad."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaikki %1$lld agenttia käyttävät samaa mallia. %2$lld yksinkertaisempaa agenttia voisi käyttää pienempää, halvempaa mallia kustannusten vähentämiseksi ilman laadun heikkenemistä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les %1$lld agents utilisent tous le même modèle. %2$lld agents plus simples pourraient utiliser un modèle plus petit et moins cher pour réduire le coût sans impact sur la qualité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tutti i %1$lld agenti usano lo stesso modello. %2$lld agenti più semplici potrebbero usare un modello più piccolo e più economico per ridurre i costi senza impatto sulla qualità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld 個すべてのエージェントが同じモデルを使用しています。よりシンプルなエージェント %2$lld 個は、より小型で安価なモデルを使用することで、品質に影響を与えずにコストを削減できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld개 에이전트가 모두 같은 모델을 사용합니다. 더 단순한 에이전트 %2$lld개는 더 작고 저렴한 모델을 사용하여 품질 저하 없이 비용을 줄일 수 있습니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wszystkich %1$lld agentów używa tego samego modelu. %2$lld prostszych agentów mogłoby użyć mniejszego, tańszego modelu, aby zmniejszyć koszty bez wpływu na jakość."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
