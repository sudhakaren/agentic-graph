    "Which tool categories map to each architecture tier. Used to assess the architecture decomposition." : {
      "comment" : "A description of the architecture component mapping section.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "فئات الأدوات التي تنطبق على كل مستوى من البنية. تُستخدم لتقييم تقسيم البنية."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jaké kategorie nástrojů odpovídají jednotlivým úrovním architektury. Slouží k posouzení dekompozice architektury."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welche Werkzeugkategorien jeder Architekturschicht zugeordnet sind. Wird zur Bewertung der Architekturzerlegung verwendet."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ποιες κατηγορίες εργαλείων αντιστοιχούν σε κάθε βαθμίδα αρχιτεκτονικής. Χρησιμοποιείται για την αξιολόγηση της αποσύνθεσης της αρχιτεκτονικής."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qué categorías de herramientas se asignan a cada nivel de arquitectura. Se utiliza para evaluar la descomposición de la arquitectura."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mitkä työkalukategoriat vastaavat kutakin arkkitehtuuritasoa. Käytetään arkkitehtuurin hajoituksen arviointiin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quelles catégories d'outils correspondent à chaque niveau d'architecture. Utilisé pour évaluer la décomposition de l'architecture."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quali categorie di strumenti sono associate a ciascun livello dell'architettura. Usato per valutare la decomposizione dell'architettura."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "どのツールカテゴリが各アーキテクチャティアに対応するかを示します。アーキテクチャの分解を評価するために使用されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "어떤 도구 범주가 각 아키텍처 등급에 매핑되는지 나타냅니다. 아키텍처 분해를 평가하는 데 사용됩니다."
          }
        },
        "pl" : {
