    "%lld of %lld tools have no error handling. Add retry, fallback, or circuit-breaker patterns to prevent cascading failures under load." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld من %2$lld أدوات لا تحتوي على معالجة أخطاء. أضف أنماط إعادة المحاولة أو البديل أو قاطع الدائرة لمنع الأعطال المتسلسلة تحت الحمل."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld z %2$lld nástrojů nemá zpracování chyb. Přidejte vzory opakování, záložní cesty nebo circuit-breakery, abyste zabránili kaskádovým chybám při zatížení."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld von %2$lld Werkzeugen haben keine Fehlerbehandlung. Füge Wiederhol-, Fallback- oder Circuit-Breaker-Muster hinzu, um Kaskadenfehler unter Last zu vermeiden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld από %2$lld εργαλεία δεν έχουν διαχείριση σφαλμάτων. Προσθέστε μοτίβα retry, fallback ή circuit-breaker για αποτροπή αλυσιδωτών αστοχιών υπό φορτίο."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld de %2$lld herramientas no tienen manejo de errores. Añade patrones de reintento, respaldo o disyuntor para evitar fallos en cascada bajo carga."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld / %2$lld työkalulla ei ole virheenkäsittelyä. Lisää uudelleenyritys-, varareitti- tai katkaisijakuvio estääksesi kaskadiset viat kuormituksessa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld outils sur %2$lld n'ont pas de gestion d'erreurs. Ajoutez des modèles de nouvelle tentative, repli ou disjoncteur pour éviter les défaillances en cascade sous charge."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld su %2$lld strumenti non hanno gestione errori. Aggiungi pattern di retry, fallback o circuit-breaker per prevenire guasti a cascata sotto carico."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%2$lld 個中 %1$lld 個のツールにエラー処理がありません。負荷時の連鎖的な障害を防ぐため、リトライ、フォールバック、サーキットブレーカーのパターンを追加してください。"
          }
