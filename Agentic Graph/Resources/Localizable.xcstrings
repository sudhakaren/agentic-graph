    "Resource estimates are calculated per this many users, then scaled proportionally if Team Size is set on the project." : {
      "comment" : "A description of how the resource estimates are calculated.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تُحسب تقديرات الموارد لكل هذا العدد من المستخدمين، ثم تُوسَّع نسبيًا إذا تم تعيين حجم الفريق في المشروع."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odhady zdrojů se počítají na tento počet uživatelů a poté se proporcionálně škálují, pokud je v projektu nastavena Velikost týmu."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ressourcenschätzungen werden pro dieser Anzahl Benutzer berechnet und dann proportional skaliert, wenn die Teamgröße im Projekt festgelegt ist."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Οι εκτιμήσεις πόρων υπολογίζονται ανά αυτόν τον αριθμό χρηστών και έπειτα κλιμακώνονται αναλογικά αν έχει οριστεί Μέγεθος ομάδας στο έργο."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las estimaciones de recursos se calculan por este número de usuarios y luego se escalan proporcionalmente si se establece el tamaño del equipo en el proyecto."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resurssiarviot lasketaan tätä käyttäjämäärää kohti ja skaalataan suhteellisesti, jos projektin tiimin koko on asetettu."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les estimations de ressources sont calculées par ce nombre d'utilisateurs, puis mises à l'échelle proportionnellement si la Taille de l'équipe est définie sur le projet."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le stime delle risorse sono calcolate per questo numero di utenti, quindi scalate proporzionalmente se la Dimensione del team è impostata sul progetto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "リソースの見積もりはこのユーザー数を基準に計算され、プロジェクトにチーム規模が設定されている場合は比例して調整されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "리소스 추정치는 이 사용자 수를 기준으로 계산되며, 프로젝트에 팀 규모가 설정된 경우 비례하여 조정됩니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Szacunki zasobów są obliczane na podstawie tej liczby użytkowników, a następnie skalowane proporcjonalnie, jeśli w projekcie ustawiono Rozmiar zespołu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As estimativas de recursos são calculadas por esse número de usuários e depois escalonadas proporcionalmente se o Tamanho da equipe estiver definido no projeto."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaynak tahminleri bu sayıda kullanıcı için hesaplanır, daha sonra projede Takım Boyutu ayarlandıysa orantılı şekilde ölçeklenir."
          }
        }
      }
    },
