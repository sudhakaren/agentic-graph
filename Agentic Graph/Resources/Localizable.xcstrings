          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anteil der maximalen Iterationen eines Agenten, der bei einem typischen Lauf und einem p95-Lauf (Worst Case) tatsächlich ausgeführt wird."
          }
