    "%lld tools with no caching — add tool result caching for frequently called, idempotent tools to reduce latency and inference costs." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld أدوات بدون تخزين مؤقت — أضف تخزينًا مؤقتًا للنتائج للأدوات المتكررة وغير القابلة للتكرار لتقليل الكمون وتكاليف الاستدلال."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld nástrojů bez cache — přidejte cache výsledků pro často volané, idempotentní nástroje pro snížení latence a nákladů na inferenci."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld Werkzeuge ohne Caching — füge Werkzeugresultat-Caching für häufig aufgerufene, idempotente Werkzeuge hinzu, um Latenz und Inferenzkosten zu reduzieren."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld εργαλεία χωρίς cache — προσθέστε cache αποτελεσμάτων για συχνά καλούμενα ιδιοδυναμικά εργαλεία για μείωση καθυστέρησης και κόστους συμπερασμού."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld herramientas sin caché — añade caché de resultados para herramientas idempotentes llamadas con frecuencia para reducir latencia y coste de inferencia."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld työkalua ilman välimuistia — lisää tulosvälimuisti usein kutsutuille, idempotenteille työkaluille latenssin ja päättelykustannusten vähentämiseksi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld outils sans cache — ajoutez du cache de résultats pour les outils idempotents fréquemment appelés afin de réduire la latence et les coûts d'inférence."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld strumenti senza cache — aggiungi cache dei risultati per strumenti idempotenti chiamati frequentemente per ridurre latenza e costi di inferenza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャッシュのないツールが %lld 個あります — 頻繁に呼び出される冪等なツールにツール結果キャッシュを追加して、レイテンシと推論コストを削減してください。"
