    "%lld large knowledge source(s) with no caching tools. RAG retrieval latency will degrade significantly under concurrent queries." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld مصادر معرفة كبيرة بدون أدوات تخزين مؤقت. سيتدهور كمون استرجاع RAG كثيرًا تحت الاستعلامات المتزامنة."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
