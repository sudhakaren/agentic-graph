    "Select an agent node to estimate its latency. Whole-solution simulation and load charts are coming next." : {
      "comment" : "A description of the load simulation feature.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حدِّد عقدة وكيل لتقدير زمن استجابتها. محاكاة الحل بالكامل ومخططات الحمل ستأتي لاحقاً."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vyberte uzel agenta pro odhad jeho latence. Simulace celého řešení a grafy zátěže budou následovat."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
