          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld von %2$lld Agenten haben kein Kostenbudget — Gefahr eines außer Kontrolle geratenen Token-Verbrauchs"
          }
