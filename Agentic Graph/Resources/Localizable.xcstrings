          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "끄기"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wyłączone"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
