    "Sent as the system instruction for every pattern evaluation." : {
      "comment" : "A description of the system prompt.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يُرسل كتعليمات نظام لكل تقييم نمط."
