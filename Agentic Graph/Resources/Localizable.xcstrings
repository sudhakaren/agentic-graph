        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokud změny neuložíte, budou ztraceny."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihre Änderungen gehen verloren, wenn Sie sie nicht sichern."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Οι αλλαγές σας θα χαθούν αν δεν τις αποθηκεύσετε."
