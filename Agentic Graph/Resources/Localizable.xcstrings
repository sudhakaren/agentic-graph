    "%lld agents have no max iterations or cost budget. Unbounded agents can consume excessive tokens during complex reasoning or retry loops." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld وكلاء بدون حد أقصى للتكرارات أو ميزانية تكلفة. يمكن للوكلاء غير المحدودين استهلاك رموز مفرطة أثناء الاستدلال المعقد أو حلقات إعادة المحاولة."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld agentů nemá maximální iterace ani rozpočet nákladů. Neomezení agenti mohou během složitého uvažování nebo opakování spotřebovat nadměrné množství tokenů."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld Agenten haben weder maximale Iterationen noch ein Kostenbudget. Unbegrenzte Agenten können bei komplexem Schlussfolgern oder Wiederholungs-Schleifen übermäßig viele Tokens verbrauchen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld πράκτορες δεν έχουν μέγιστες επαναλήψεις ή προϋπολογισμό κόστους. Οι μη φραγμένοι πράκτορες μπορούν να καταναλώσουν υπερβολικά token κατά τη διάρκεια σύνθετου συλλογισμού ή βρόχων επανάληψης."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld agentes no tienen iteraciones máximas ni presupuesto de coste. Los agentes sin límites pueden consumir tokens excesivos durante razonamientos complejos o bucles de reintento."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld agentilla ei ole maksimi-iteraatioita tai kustannusbudjettia. Rajoittamattomat agentit voivat kuluttaa liikaa tokeneita monimutkaisen päättelyn tai uudelleenyrityssilmukoiden aikana."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld agents n'ont pas d'itérations maximales ni de budget de coût. Les agents non bornés peuvent consommer trop de jetons lors de raisonnements complexes ou de boucles de nouvelles tentatives."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld agenti non hanno iterazioni massime né budget di costo. Gli agenti senza limiti possono consumare token in eccesso durante ragionamenti complessi o cicli di retry."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最大反復回数もコスト予算も設定されていないエージェントが %lld 個あります。制限のないエージェントは、複雑な推論やリトライループ中に過剰なトークンを消費する可能性があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "최대 반복 횟수나 비용 예산이 없는 에이전트가 %lld개 있습니다. 제한이 없는 에이전트는 복잡한 추론이나 재시도 루프 중에 과도한 토큰을 소비할 수 있습니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld agentów nie ma maksymalnej liczby iteracji ani budżetu kosztów. Nieograniczeni agenci mogą zużywać nadmierne tokeny podczas złożonego rozumowania lub pętli ponawiania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld agentes não têm iterações máximas ou orçamento de custo. Agentes sem limites podem consumir tokens em excesso durante raciocínios complexos ou loops de repetição."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld aracının maksimum yineleme veya maliyet bütçesi yok. Sınırsız aracılar karmaşık akıl yürütme veya yeniden deneme döngüleri sırasında aşırı token tüketebilir."
          }
        }
      }
    },
