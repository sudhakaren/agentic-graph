    "Inference requests generated per delegating agent. Low = shallow delegation, High = deep delegation chains." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "طلبات الاستدلال المنشأة لكل وكيل مفوِّض. منخفض = تفويض سطحي، مرتفع = سلاسل تفويض عميقة."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inferenční požadavky vygenerované na delegujícího agenta. Nízká = mělká delegace, Vysoká = hluboké delegační řetězce."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inferenzanfragen pro delegierendem Agent. Niedrig = oberflächliche Delegation, Hoch = tiefe Delegationsketten."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αιτήματα συμπερασμού ανά πράκτορα που αναθέτει. Χαμηλό = ρηχή ανάθεση, Υψηλό = βαθιές αλυσίδες ανάθεσης."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solicitudes de inferencia generadas por agente delegante. Bajo = delegación superficial, Alto = cadenas de delegación profundas."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Päättelypyyntöjä, jotka tuotetaan delegoivaa agenttia kohti. Matala = matala delegointi, korkea = syvät delegointiketjut."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Requêtes d'inférence générées par agent délégant. Faible = délégation superficielle, Élevé = chaînes de délégation profondes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Richieste di inferenza generate per agente delegante. Basso = delega superficiale, Alto = catene di delega profonde."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "委任を行うエージェントごとに生成される推論リクエスト数です。低 = 浅い委任、高 = 深い委任チェーン。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "위임하는 에이전트당 생성되는 추론 요청 수입니다. 낮음 = 얕은 위임, 높음 = 깊은 위임 체인."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Żądania wnioskowania na delegującego agenta. Niski = płytka delegacja, Wysoki = głębokie łańcuchy delegowania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solicitações de inferência geradas por agente delegante. Baixo = delegação superficial, Alto = cadeias de delegação profundas."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yetki devreden aracı başına oluşturulan çıkarım istekleri. Düşük = yüzeysel yetki devri, Yüksek = derin yetki devri zincirleri."
          }
        }
      }
    },
