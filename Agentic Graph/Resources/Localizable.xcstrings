    "Translate the prompt field into %@. Change in Settings → Prompt Analysis." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ترجمة حقل الموجه إلى %@. غيِّر ذلك من الإعدادات ← تحليل الموجه."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přeložit pole promptu do %@. Změňte v Nastavení → Analýza promptu."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prompt-Feld in %@ übersetzen. Ändere es in Einstellungen → Prompt-Analyse."
