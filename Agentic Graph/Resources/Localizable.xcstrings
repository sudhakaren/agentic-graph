          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Χρησιμοποιεί το IBM Cloud IAM για ταυτοποίηση. Το κλειδί API ανταλλάσσεται αυτόματα με bearer token."
