    "%lld of %lld agents have no cost budget — risk of runaway token consumption" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld من %2$lld وكلاء بدون ميزانية تكلفة — خطر استهلاك مفرط للرموز"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
