          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se envía como instrucción del sistema en cada evaluación de patrón."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lähetetään järjestelmäohjeena jokaiselle mallianalyysille."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Envoyé comme instruction système pour chaque évaluation de motif."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inviato come istruzione di sistema per ogni valutazione del pattern."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべてのパターン評価でシステム指示として送信されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모든 패턴 평가에서 시스템 지침으로 전송됩니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wysyłane jako instrukcja systemu dla każdej oceny wzorca."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
