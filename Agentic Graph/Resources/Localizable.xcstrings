    "Estimates based on graph structure and sizing rules of thumb. Actual requirements may vary." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "التقديرات مبنية على بنية الرسم البياني وقواعد عامة لتحديد الحجم. قد تختلف المتطلبات الفعلية."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odhady jsou založeny na struktuře grafu a empirických pravidlech dimenzování. Skutečné požadavky se mohou lišit."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schätzungen basieren auf der Graphstruktur und Größenbestimmungs-Faustregeln. Die tatsächlichen Anforderungen können abweichen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Εκτιμήσεις βάσει της δομής του γράφου και εμπειρικών κανόνων διαστασιολόγησης. Οι πραγματικές απαιτήσεις ενδέχεται να διαφέρουν."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estimaciones basadas en la estructura del grafo y reglas empíricas de dimensionamiento. Los requisitos reales pueden variar."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arviot perustuvat graafin rakenteeseen ja mitoituksen nyrkkisääntöihin. Todelliset vaatimukset voivat vaihdella."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estimations basées sur la structure du graphe et des règles empiriques de dimensionnement. Les besoins réels peuvent varier."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stime basate sulla struttura del grafo e su regole pratiche di dimensionamento. I requisiti effettivi possono variare."
