    "Seconds for one tool call, by tool type. Sync tools add up; async tools overlap." : {
      "comment" : "A description of the latency of a tool.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عدد الثواني لاستدعاء أداة واحدة، حسب نوع الأداة. الأدوات المتزامنة تتراكم؛ والأدوات غير المتزامنة تتداخل."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sekundy na jedno volání nástroje podle typu nástroje. Synchronní nástroje se sčítají, asynchronní se překrývají."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sekunden für einen Tool-Aufruf, nach Tool-Typ. Synchrone Tools summieren sich, asynchrone überlappen sich."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Δευτερόλεπτα για μία κλήση εργαλείου, ανά τύπο εργαλείου. Τα σύγχρονα εργαλεία αθροίζονται· τα ασύγχρονα επικαλύπτονται."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segundos por una llamada a herramienta, según el tipo. Las herramientas síncronas se suman; las asíncronas se solapan."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sekunteja yhtä työkalukutsua kohden työkalutyypin mukaan. Synkroniset työkalut lasketaan yhteen, asynkroniset limittyvät."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Secondes pour un appel d'outil, selon le type. Les outils synchrones s'additionnent ; les outils asynchrones se chevauchent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Secondi per una chiamata dello strumento, in base al tipo. Gli strumenti sincroni si sommano; quelli asincroni si sovrappongono."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ツール呼び出し1回あたりの秒数（ツールタイプ別）。同期ツールは加算され、非同期ツールは並行します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "도구 호출 1회당 초, 도구 유형별. 동기 도구는 합산되고 비동기 도구는 겹칩니다."
          }
        },
        "pl" : {
