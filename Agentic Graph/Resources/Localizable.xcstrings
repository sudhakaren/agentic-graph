    "Optional reverse target — enables a second Translate button that converts back into this language. Leave empty to hide the button." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هدف عكسي اختياري — يفعِّل زر ترجمة ثانٍ يحوِّل النص إلى هذه اللغة. اتركه فارغًا لإخفاء الزر."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Volitelný opačný cíl — povolí druhé tlačítko Přeložit, které převede zpět do tohoto jazyka. Pro skrytí tlačítka nechte prázdné."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Optionales Umkehrziel — aktiviert eine zweite Übersetzen-Schaltfläche, die in diese Sprache zurückübersetzt. Leer lassen, um die Schaltfläche auszublenden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Προαιρετικός αντίστροφος στόχος — ενεργοποιεί ένα δεύτερο κουμπί Μετάφραση που μετατρέπει πίσω σε αυτήν τη γλώσσα. Αφήστε κενό για να αποκρύψετε το κουμπί."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Destino inverso opcional — activa un segundo botón de Traducir que vuelve a este idioma. Déjalo vacío para ocultar el botón."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Valinnainen käänteinen kohde — käyttöön tulee toinen Käännä-painike, joka muuntaa takaisin tälle kielelle. Jätä tyhjäksi piilottaaksesi painikkeen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cible inverse facultative — active un second bouton Traduire qui reconvertit dans cette langue. Laissez vide pour masquer le bouton."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Destinazione inversa opzionale — abilita un secondo pulsante Traduci che riconverte in questa lingua. Lascia vuoto per nascondere il pulsante."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "任意の逆方向ターゲット — この言語に戻す2つ目の「翻訳」ボタンを有効にします。空欄のままにするとボタンは非表示になります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "선택적 역방향 대상 — 이 언어로 다시 변환하는 두 번째 '번역' 버튼을 활성화합니다. 비워 두면 버튼이 숨겨집니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opcjonalny cel odwrotny — włącza drugi przycisk Tłumacz, który zwraca tekst do tego języka. Pozostaw puste, aby ukryć przycisk."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Destino reverso opcional — habilita um segundo botão Traduzir que converte de volta para este idioma. Deixe vazio para ocultar o botão."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opsiyonel ters hedef — bu dile geri çeviren ikinci bir Çevir düğmesini etkinleştirir. Düğmeyi gizlemek için boş bırakın."
          }
        }
      }
    },
