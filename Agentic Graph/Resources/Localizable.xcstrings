    "If the %lld sync tool(s) ran async, typical latency drops to about %@ (from %@)." : {
      "comment" : "A sentence that describes the typical latency of a system if its sync tools run asynchronously. The second argument is the string “%argms” or the string “%.1fs”. The third argument is the string “%argms” or the string “%.1fs”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا تم تشغيل أدوات المزامنة الـ %lld بشكل غير متزامن، فسينخفض زمن الاستجابة النموذجي إلى حوالي %@ (من %@)."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokud by %lld synchronních nástrojů běželo asynchronně, typická latence klesne přibližně na %@ (z %@)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn die %lld synchronen Tools asynchron liefen, sinkt die typische Latenz auf etwa %@ (von %@)."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αν τα %lld σύγχρονα εργαλεία εκτελούνταν ασύγχρονα, η τυπική καθυστέρηση πέφτει περίπου στα %@ (από %@)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "If the %1$lld sync tool(s) ran async, typical latency drops to about %2$@ (from %3$@)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si las %lld herramientas síncronas se ejecutaran de forma asíncrona, la latencia típica baja a aproximadamente %@ (desde %@)."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jos %lld synkronista työkalua suoritettaisiin asynkronisesti, tyypillinen viive laskee noin arvoon %@ (arvosta %@)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si les %lld outils synchrones s'exécutaient de manière asynchrone, la latence typique tombe à environ %@ (contre %@)."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se i %lld strumenti sincroni venissero eseguiti in modo asincrono, la latenza tipica scende a circa %@ (da %@)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld 個の同期ツールを非同期で実行した場合、標準的なレイテンシは約 %@ に短縮されます（現在は %@）。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld개의 동기 도구를 비동기로 실행하면 일반 지연 시간이 약 %@(으)로 줄어듭니다(현재 %@)."
          }
        },
        "pl" : {
