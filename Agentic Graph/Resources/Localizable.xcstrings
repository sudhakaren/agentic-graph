    "Merged “%@” — %lld updated, %lld added, %lld not in the merged file. Snapshots saved before and after; any nodes not in the merged file are selected for review." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم دمج “%@” — %lld محدّث، %lld مُضاف، %lld غير موجود في الملف المدموج. تم حفظ لقطات قبل وبعد، والعقد غير الموجودة في الملف محدّدة للمراجعة."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sloučeno “%@” — %lld aktualizováno, %lld přidáno, %lld není ve sloučeném souboru. Snímky uloženy před a po; uzly chybějící ve sloučeném souboru jsou vybrány ke kontrole."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” zusammengeführt — %lld aktualisiert, %lld hinzugefügt, %lld nicht in der zusammengeführten Datei. Schnappschüsse vorher und nachher gespeichert; Knoten, die nicht in der zusammengeführten Datei enthalten sind, sind zur Überprüfung ausgewählt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Συγχωνεύτηκε το “%@” — %lld ενημερώθηκαν, %lld προστέθηκαν, %lld δεν υπάρχουν στο συγχωνευμένο αρχείο. Αποθηκεύτηκαν στιγμιότυπα πριν και μετά· οι κόμβοι που λείπουν από το συγχωνευμένο αρχείο είναι επιλεγμένοι για έλεγχο."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se fusionó “%@” — %lld actualizados, %lld añadidos, %lld no están en el archivo fusionado. Se guardaron instantáneas antes y después; los nodos que no están en el archivo fusionado quedan seleccionados para revisión."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yhdistetty “%@” — %lld päivitetty, %lld lisätty, %lld ei yhdistetyssä tiedostossa. Tilannekuvat tallennettiin ennen ja jälkeen; yhdistetystä tiedostosta puuttuvat solmut on valittu tarkistettavaksi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” fusionné — %lld mis à jour, %lld ajoutés, %lld absents du fichier fusionné. Des instantanés ont été enregistrés avant et après ; les nœuds absents du fichier fusionné sont sélectionnés pour révision."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” unito — %lld aggiornati, %lld aggiunti, %lld non presenti nel file unito. Istantanee salvate prima e dopo; i nodi non presenti nel file unito sono selezionati per la revisione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」をマージしました — 更新 %lld、追加 %lld、マージしたファイルにないもの %lld。前後にスナップショットを保存しました。マージしたファイルにないノードはレビュー用に選択されています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” 병합됨 — %lld개 업데이트, %lld개 추가, %lld개는 병합한 파일에 없음. 전후로 스냅샷이 저장되었습니다. 병합한 파일에 없는 노드는 검토를 위해 선택됩니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scalono “%@” — %lld zaktualizowano, %lld dodano, %lld brak w scalonym pliku. Migawki zapisano przed i po; węzły nieobecne w scalonym pliku są zaznaczone do przejrzenia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” mesclado — %lld atualizados, %lld adicionados, %lld não estão no arquivo mesclado. Instantâneos salvos antes e depois; os nós ausentes do arquivo mesclado ficam selecionados para revisão."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” birleştirildi — %lld güncellendi, %lld eklendi, %lld birleştirilen dosyada yok. Önce ve sonra anlık görüntüler kaydedildi; birleştirilen dosyada olmayan düğümler inceleme için seçili."
          }
        }
      }
    },
    "Merged “%@” — %lld updated, %lld added, %lld removed. A version snapshot was saved first." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم دمج “%@” — %lld محدّث، %lld مُضاف، %lld مُزال. تم حفظ لقطة للإصدار أولاً."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sloučeno “%@” — %lld aktualizováno, %lld přidáno, %lld odebráno. Nejprve byl uložen snímek verze."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” zusammengeführt — %lld aktualisiert, %lld hinzugefügt, %lld entfernt. Zuvor wurde ein Versions-Schnappschuss gespeichert."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Συγχωνεύτηκε το “%@” — %lld ενημερώθηκαν, %lld προστέθηκαν, %lld αφαιρέθηκαν. Πρώτα αποθηκεύτηκε ένα στιγμιότυπο έκδοσης."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se fusionó “%@” — %lld actualizados, %lld añadidos, %lld eliminados. Primero se guardó una instantánea de versión."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yhdistetty “%@” — %lld päivitetty, %lld lisätty, %lld poistettu. Versiotilannekuva tallennettiin ensin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” fusionné — %lld mis à jour, %lld ajoutés, %lld supprimés. Un instantané de version a d’abord été enregistré."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” unito — %lld aggiornati, %lld aggiunti, %lld rimossi. Prima è stata salvata un’istantanea della versione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」をマージしました — 更新 %lld、追加 %lld、削除 %lld。先にバージョンスナップショットを保存しました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” 병합됨 — %lld개 업데이트, %lld개 추가, %lld개 제거. 먼저 버전 스냅샷이 저장되었습니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scalono “%@” — %lld zaktualizowano, %lld dodano, %lld usunięto. Najpierw zapisano migawkę wersji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” mesclado — %lld atualizados, %lld adicionados, %lld removidos. Um instantâneo de versão foi salvo primeiro."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” birleştirildi — %lld güncellendi, %lld eklendi, %lld kaldırıldı. Önce bir sürüm anlık görüntüsü kaydedildi."
          }
        }
      }
