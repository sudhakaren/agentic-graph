          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld de %2$lld ferramentas não têm tratamento de erros. Adicione padrões de retry, fallback ou circuit-breaker para evitar falhas em cascata sob carga."
          }
        },
